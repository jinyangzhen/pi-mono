{
  "name": "@mariozechner/tian-gong-fronts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",

    "_comment_check": "=== Type Checking ===",
    "check": "tsc --noEmit",

    "_comment_build": "=== Build Commands ===",
    "build": "tsc && vite build",
    "build:host": "vite build",
    "build:chat": "FEDERATION=true vite build --config vite.config.chat.ts",
    "build:terminal": "FEDERATION=true vite build --config vite.config.terminal.ts",
    "build:remotes": "npm run build:chat && npm run build:terminal",
    "build:all": "npm run build:remotes && npm run build:host",

    "_comment_standalone": "=== Standalone Dev (No Federation) ===",
    "dev:chat": "vite --config vite.config.chat.ts",
    "dev:terminal": "vite --config vite.config.terminal.ts",
    "dev:standalone": "concurrently -n chat,terminal -c green,yellow \"vite --config vite.config.chat.ts\" \"vite --config vite.config.terminal.ts\"",

    "_comment_preview": "=== Preview Built Apps ===",
    "preview": "vite preview",
    "preview:host": "vite preview --port 3000",
    "preview:chat": "vite preview --config vite.config.chat.ts --port 4001",
    "preview:terminal": "vite preview --config vite.config.terminal.ts --port 4002",

    "_comment_federated": "=== Federated Dev (Host + Remotes) ===",
    "dev:all": "npm run build:all && concurrently -n host,chat,terminal -c blue,green,yellow \"vite preview --port 3000\" \"vite preview --config vite.config.chat.ts --port 4001\" \"vite preview --config vite.config.terminal.ts --port 4002\""
  },
  "dependencies": {
    "@mariozechner/mini-lit": "^0.2.0",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lit": "^3.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
